{
  "regions": ["icn1"],
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/collect", "dest": "/api/collect.py" },
    { "src": "/api/macro", "dest": "/api/macro.py" },
    { "src": "/api/rankings", "dest": "/api/rankings.py" },
    { "src": "/api/rankings-periods", "dest": "/api/rankings_periods.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/rankings_periods.py": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    }
  ]
}
