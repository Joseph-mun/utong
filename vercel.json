{
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/macro", "dest": "/api/macro.py" },
    { "src": "/api/rankings", "dest": "/api/rankings.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
